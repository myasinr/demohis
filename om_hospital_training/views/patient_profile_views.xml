<odoo>
    <record id="view_hospital_patient_profile_tree" model="ir.ui.view">
        <field name="name">hospital.patient.profile.tree</field>
        <field name="model">hospital.patient.profile</field>
        <field name="arch" type="xml">
            <tree>
                <field name="profile_code"/>
                <field name="reference"/>
                <field name="name"/>
                <field name="mobile"/>
            </tree>
        </field>
    </record>
    <record id="view_hospital_patient_profile_form" model="ir.ui.view">
        <field name="name">hospital.patient.profile.form</field>
        <field name="model">hospital.patient.profile</field>
        <field name="arch" type="xml">
            <form string="Patient Profile Delegation Demo">
                <sheet>
                    <group>
                        <field name="patient_id"/>
                        <field name="profile_code"/>
                        <field name="profile_notes"/>
                    </group>
                    <group string="Delegated Patient Fields">
                        <field name="reference" readonly="1"/>
                        <field name="name"/>
                        <field name="mobile"/>
                        <field name="email"/>
                        <field name="doctor_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_patient_profile" model="ir.actions.act_window">
        <field name="name">Delegation Inheritance Profiles</field>
        <field name="res_model">hospital.patient.profile</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_hospital_patient_profile" name="Delegation Inheritance: Profiles" parent="menu_hospital_demo" action="action_hospital_patient_profile" sequence="20"/>
</odoo>
