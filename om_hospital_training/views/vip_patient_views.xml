<odoo>
    <record id="view_hospital_vip_patient_tree" model="ir.ui.view">
        <field name="name">hospital.vip.patient.tree</field>
        <field name="model">hospital.vip.patient</field>
        <field name="arch" type="xml">
            <tree>
                <field name="reference"/>
                <field name="name"/>
                <field name="mobile"/>
                <field name="vip_level"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_hospital_vip_patient_form" model="ir.ui.view">
        <field name="name">hospital.vip.patient.form</field>
        <field name="model">hospital.vip.patient</field>
        <field name="arch" type="xml">
            <form string="VIP Patient Classical Inheritance Demo">
                <sheet>
                    <group>
                        <field name="reference" readonly="1"/>
                        <field name="name"/>
                        <field name="mobile"/>
                        <field name="email"/>
                        <field name="vip_level"/>
                        <field name="vip_notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_hospital_vip_patient" model="ir.actions.act_window">
        <field name="name">VIP Patient Classical Inheritance</field>
        <field name="res_model">hospital.vip.patient</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_hospital_vip_patient" name="Classical Inheritance: VIP Patients" parent="menu_hospital_demo" action="action_hospital_vip_patient" sequence="10"/>
</odoo>
