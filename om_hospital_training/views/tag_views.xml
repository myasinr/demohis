<odoo>
    <record id="view_hospital_patient_tag_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tag.tree</field>
        <field name="model">hospital.patient.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="color"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="action_hospital_patient_tag" model="ir.actions.act_window">
        <field name="name">Patient Tags</field>
        <field name="res_model">hospital.patient.tag</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_hospital_patient_tag" name="Patient Tags" parent="menu_hospital_configuration" action="action_hospital_patient_tag" sequence="20"/>
</odoo>
