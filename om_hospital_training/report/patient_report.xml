<odoo>
    <report id="action_report_hospital_patient"
            model="hospital.patient"
            string="Patient Registration Form"
            report_type="qweb-pdf"
            name="om_hospital_training.report_hospital_patient_document"
            file="om_hospital_training.report_hospital_patient_document"
            print_report_name="'Patient - %s' % (object.reference)"/>

    <template id="report_hospital_patient_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Patient Registration Form</h2>
                        <table class="table table-sm">
                            <tr><td><strong>Reference</strong></td><td><span t-field="doc.reference"/></td></tr>
                            <tr><td><strong>Name</strong></td><td><span t-field="doc.name"/></td></tr>
                            <tr><td><strong>Age</strong></td><td><span t-field="doc.age"/></td></tr>
                            <tr><td><strong>Gender</strong></td><td><span t-field="doc.gender"/></td></tr>
                            <tr><td><strong>Mobile</strong></td><td><span t-field="doc.mobile"/></td></tr>
                            <tr><td><strong>Doctor</strong></td><td><span t-field="doc.doctor_id"/></td></tr>
                            <tr><td><strong>Status</strong></td><td><span t-field="doc.state"/></td></tr>
                        </table>
                        <h4>Notes</h4>
                        <p><span t-field="doc.note"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
