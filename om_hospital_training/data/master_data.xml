<odoo>
    <record id="department_general" model="hospital.department">
        <field name="name">General Medicine</field>
        <field name="code">GEN</field>
    </record>
    <record id="department_child" model="hospital.department">
        <field name="name">Child Care</field>
        <field name="code">CHILD</field>
    </record>
    <record id="tag_diabetes" model="hospital.patient.tag">
        <field name="name">Diabetes</field>
        <field name="color">2</field>
    </record>
    <record id="tag_emergency" model="hospital.patient.tag">
        <field name="name">Emergency</field>
        <field name="color">1</field>
    </record>
    <record id="medicine_paracetamol" model="hospital.medicine">
        <field name="name">Paracetamol</field>
        <field name="code">MED-PARA</field>
        <field name="price">50</field>
    </record>
    <record id="medicine_vitamin" model="hospital.medicine">
        <field name="name">Vitamin Supplement</field>
        <field name="code">MED-VIT</field>
        <field name="price">100</field>
    </record>
</odoo>
