<odoo>
    <record id="module_category_hospital_training" model="ir.module.category">
        <field name="name">Hospital Training</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_hospital_receptionist" model="res.groups">
        <field name="name">Hospital Receptionist</field>
        <field name="category_id" ref="module_category_hospital_training"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hospital_doctor" model="res.groups">
        <field name="name">Hospital Doctor</field>
        <field name="category_id" ref="module_category_hospital_training"/>
        <field name="implied_ids" eval="[(4, ref('group_hospital_receptionist'))]"/>
    </record>

    <record id="group_hospital_manager" model="res.groups">
        <field name="name">Hospital Manager</field>
        <field name="category_id" ref="module_category_hospital_training"/>
        <field name="implied_ids" eval="[(4, ref('group_hospital_doctor'))]"/>
    </record>
</odoo>
