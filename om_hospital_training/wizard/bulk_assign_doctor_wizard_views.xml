<odoo>
    <record id="view_bulk_assign_doctor_wizard_form" model="ir.ui.view">
        <field name="name">hospital.bulk.assign.doctor.wizard.form</field>
        <field name="model">hospital.bulk.assign.doctor.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Doctor in Bulk">
                <group>
                    <field name="patient_count" readonly="1"/>
                    <field name="doctor_id" options="{'no_create': True}"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_assign_doctor" string="Assign Doctor" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
